{
  "expo": {
    "name": "Parko Control",
    "slug": "Parko-Control",
    "version": "1.2.2",
    "scheme": "parko-control",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#890350"
    },
    "runtimeVersion": "1.2.2",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parkocontrol.bordeac03",
      "buildNumber": "5",
      "infoPlist": {
		"UIViewControllerBasedStatusBarAppearance": true,
		"NSBluetoothAlwaysUsageDescription": "Allow $(PRODUCT_NAME) to connect to Bluetooth receipt printers.",
		"NSBluetoothPeripheralUsageDescription": "Allow $(PRODUCT_NAME) to connect to Bluetooth receipt printers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#890350"
      },
      "package": "com.parkocontrol.bordeac03",
      "versionCode": 5,
    "softwareKeyboardLayoutMode": "pan",
    "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2fa64f0c-98bb-472a-a2a8-b0f4b92a2c14"
      }
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location at all times",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location when the app is in use"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
